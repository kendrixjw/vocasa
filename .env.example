# Committed template documenting required env vars. Copy to .env.local and fill in.
# Both are PUBLIC values (safe to expose to the browser); Supabase Row Level
# Security enforces per-user access. Never put the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Absolute base URL of this deployment. Used for auth email redirects
# (password reset, magic link) and MUST exactly match a Supabase Redirect URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side only (never exposed to the browser). Powers voice/text parsing
# and design assist. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
