# Copy to .env.local and fill in. .env.local is gitignored.

# Server-side only — used to proxy AI parse/assist calls. NEVER exposed to the client.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (Phase 9 persistence). Both are PUBLIC values; Row Level Security
# enforces per-user access. Leave unset to run the app in local-only mode.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. Lets the Stripe webhook credit any user's account (bypasses
# RLS). NEVER expose to the client. Found in Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel AI Gateway (premium redesign renders). Provisioned by `vercel env pull`
# as VERCEL_OIDC_TOKEN, or set a static AI_GATEWAY_API_KEY for non-Vercel envs.
# AI_GATEWAY_API_KEY=...

# Stripe billing for render credits. Secret key + webhook signing secret, plus
# the Price IDs for each pack/tier (products with an unset price are hidden).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PACK_30=price_...
STRIPE_PRICE_PACK_100=price_...
STRIPE_PRICE_TIER_STANDARD=price_...
STRIPE_PRICE_TIER_PRO=price_...
